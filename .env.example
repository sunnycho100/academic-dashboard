# Academic Dashboard Environment Variables

# Storage mode: "json" (default) or "postgres"
# JSON mode:     data stored in data/*.json — no Docker needed
# Postgres mode: data stored in PostgreSQL — requires Docker
STORAGE_MODE=json

# Your display name shown on the landing greeting screen
USER_NAME=YourName

# PostgreSQL connection string (only needed for STORAGE_MODE=postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/academic_dashboard"

# If you want to deploy this to Vercel or another platform:
# NEXT_PUBLIC_APP_URL=https://your-domain.com
